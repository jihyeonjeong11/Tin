{
  "name": "@tin/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@tin/shared": "workspace:*",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "vitest": "catalog:"
  }
}
